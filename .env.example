# PostgreSQL (Neon)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Groq LLM
GROQ_API_KEY="gsk_..."

# Notion archive
NOTION_TOKEN="ntn_..."
NOTION_DB_ID="00000000-0000-0000-0000-000000000000"

# Telegram digest
TELEGRAM_TOKEN="000000:AAA..."
TELEGRAM_CHAT_ID="000000000"

# Optional knobs
KEYWORDS="python,odoo,ia,full stack,remoto"
DIGEST_TOP_N="3"
MIN_FIT_SCORE="60"
# UI/prompt language: es (default) or en
JOB_ALERT_LANG="es"
